<UserControl x:Class="ProgressApp.WpfUI.Views.InitialSetup.InitialSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:ProgressApp.WpfUI.Helpers"
             TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
 
            <StackPanel Width="400">

                <ui:SymbolIcon Symbol="Star24" FontSize="48" Margin="0,0,0,15" 
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>

                <ui:TextBlock Text="{Binding Source={StaticResource Langs}, Path=[Title_Welcome]}" 
                              FontSize="28"
                              FontWeight="Bold"
                              Margin="0,0,0,30"
                              HorizontalAlignment="Center"/>

                <ui:Card Padding="20">
                    <StackPanel>
                        <Label Content="{Binding Source={StaticResource Langs}, Path=[Title_username]}" Margin="0,0,0,5"/>
                        <ui:TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                    Icon="{ui:SymbolIcon Symbol=Person24}"
                                    PlaceholderText="{Binding Source={StaticResource Langs}, Path=[Placeholder_HowCallYou]}"
                                    MaxLength="35" 
                                    TabIndex="1"
                                    Margin="0,0,0,15"/>

                        <Label Content="{Binding Source={StaticResource Langs}, Path=[Title_YourGoal]}" Margin="0,0,0,5"/>

                    <ScrollViewer Height="80" VerticalScrollBarVisibility="Visible">
                        <TextBox Text="{Binding Goal, UpdateSourceTrigger=PropertyChanged}" 
                                    MaxLength="150"
                                    TextWrapping="Wrap"        
                                    AcceptsReturn="True"       
                                    VerticalContentAlignment="Top"
                                    TabIndex="2"
                                    Margin="0,0,0,15"/>
                    </ScrollViewer>
                    <Label Content="{Binding Source={StaticResource Langs}, Path=[Title_password]}" Margin="0,0,0,5"/>
                        <ui:PasswordBox Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Icon="{ui:SymbolIcon Symbol=Password24}"
                                        PlaceholderText="{Binding Source={StaticResource Langs}, Path=[Placeholder_Max8Ch]}"
                                        MaxLength="8"
                                        TabIndex="3"
                                        Margin="0,0,0,15"
                                        PreviewKeyDown="PasswordBox_PreviewKeyDown"
                                        DataObject.Pasting="PasswordBox_Pasting"/>

                    <Label Content="{Binding Source={StaticResource Langs}, Path=[Title_ConfirmPassword]}" Margin="0,0,0,5"/>
                    <ui:PasswordBox Password="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Icon="{ui:SymbolIcon Symbol=Password24}"
                                        PlaceholderText="{Binding Source={StaticResource Langs}, Path=[Placeholder_Max8Ch]}"
                                        MaxLength="8"
                                        TabIndex="4"
                                        Margin="0,0,0,15"
                                        PreviewKeyDown="PasswordBox_PreviewKeyDown"
                                        DataObject.Pasting="PasswordBox_Pasting"/>


                    <Label Content="{Binding Source={StaticResource Langs}, Path=[Title_SelectLanguage]}" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}" 
                                     SelectedItem="{Binding SelectedLanguage}"
                                     HorizontalAlignment="Stretch"
                                     Margin="0,0,0,10">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </ui:Card>

                <ui:Button Content="{Binding Source={StaticResource Langs}, Path=[Title_Start]}" 
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon Symbol=Play24}"
                           FontSize="16"
                           Padding="0,12"
                           Margin="0,30,0,0"
                           Command="{Binding FinishCommand}"
                           HorizontalAlignment="Stretch"
                           IsDefault="True"/>

            </StackPanel>
    </ScrollViewer>
</UserControl>