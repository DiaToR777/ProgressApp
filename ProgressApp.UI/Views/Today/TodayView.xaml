<UserControl x:Class="ProgressApp.WpfUI.Views.Today.TodayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ProgressApp.WpfUI.ViewModels.Today"
             xmlns:helpers="clr-namespace:ProgressApp.WpfUI.Localization.Helpers"
             xmlns:conv="clr-namespace:ProgressApp.WpfUI.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:TodayViewModel}"
             >
    <UserControl.Resources>
        <conv:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter"/>
    </UserControl.Resources>
    <StackPanel Margin="20"
                helpers:LanguageHelper.UpdateLanguage="{Binding Source={StaticResource Langs}, Path=CurrentCulture}">
                    
        <Grid Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Source={StaticResource Langs}, Path=[Title_Today]}"
                   FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="{Binding CurrentDate, StringFormat=dd MMMM yyyy}"
                   Margin="10,7,0,0"
                   FontSize="14"
                           />
            </StackPanel>

            <TextBlock HorizontalAlignment="Right" 
               VerticalAlignment="Bottom"
               Foreground="Gray"
               FontSize="12">
        <Run Text="{Binding Description.Length, Mode=OneWay}"/>
        <Run Text="/1500"/>
            </TextBlock>
        </Grid>

        <Border Background="#1A111111" CornerRadius="8" Padding="10,5" HorizontalAlignment="Left" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔥" FontSize="18" VerticalAlignment="Center" Margin="0,0,5,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="Opacity" Value="0.5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStreak, Converter={StaticResource GreaterThanZeroConverter}}" Value="True">
                                    <Setter Property="Foreground" Value="OrangeRed"/>
                                    <Setter Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
                <TextBlock Text="{Binding CurrentStreak}" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center"/>

                <TextBlock Text=" day(s) streak" 
                   FontSize="12" 
                   Foreground="Gray" 
                   VerticalAlignment="Bottom" 
                   Margin="5,0,0,2"/>
            </StackPanel>
        </Border>
        
        <Label Content="{Binding Source={StaticResource Langs}, Path=[Title_DayDescription]}"/>
        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                 Height="120"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 MaxLength="1500"
                 />

        <Label Content="{Binding Source={StaticResource Langs}, Path=[DataGrid_Result]}" ContentStringFormat="{}{0}:" />

        <ComboBox ItemsSource="{Binding AllResult}" 
          SelectedValue="{Binding SelectedResult}"
          SelectedValuePath="Value"
          Margin="0,0,0,10">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <Button Content="{Binding Source={StaticResource Langs}, Path=[Btn_SaveDay]}"
                Margin="0,10"
                Command="{Binding SaveCommand}"
                />
    </StackPanel>
</UserControl>
