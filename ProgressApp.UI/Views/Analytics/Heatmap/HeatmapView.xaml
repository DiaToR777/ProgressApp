<UserControl x:Class="ProgressApp.WpfUI.Views.Analytics.Heatmap.HeatmapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProgressApp.WpfUI.Views.Analytics"
             xmlns:conv="clr-namespace:ProgressApp.WpfUI.Converters.Heatmap">
    <UserControl.Resources>
        <conv:DayResultToColorConverter x:Key="ResultToColor"/>

        <!-- Стиль одной ячейки -->
        <Style x:Key="DayCellStyle" TargetType="Border">
            <Setter Property="Width"        Value="16"/>
            <Setter Property="Height"       Value="16"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin"       Value="2"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.75"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal">

        <!-- Подписи дней недели -->
        <StackPanel Margin="0,20,4,0">
            <TextBlock Text="Пн" Height="20" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
            <TextBlock Text="Вт" Height="20" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
            <TextBlock Text="Ср" Height="20" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
            <TextBlock Text="Чт" Height="20" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
            <TextBlock Text="Пт" Height="20" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
            <TextBlock Text="Сб" Height="20" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
            <TextBlock Text="Вс" Height="20" FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Сетка недель -->
        <ItemsControl ItemsSource="{Binding Weeks}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <!-- Горизонтальный WrapPanel — каждый item = столбец-неделя -->
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- Одна неделя = вертикальный столбец из 7 ячеек -->
                    <ItemsControl ItemsSource="{Binding}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DayCellStyle}"
                                        Background="{Binding Result, 
                                                     Converter={StaticResource ResultToColor},
                                                     TargetNullValue='#D3D1C7'}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Date, StringFormat='{}{0:dd MMMM yyyy}'}"
                                                           FontWeight="Medium"/>
                                                <TextBlock Text="{Binding Result}"
                                                           Foreground="Gray" FontSize="12"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <!-- Клик по ячейке -->
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.CellClickCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
