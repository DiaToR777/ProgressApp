<UserControl x:Class="ProgressApp.WpfUI.Views.Table.TableView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:ProgressApp.WpfUI.Localization.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid Margin="10"
          helpers:LanguageHelper.UpdateLanguage="{Binding Source={StaticResource Langs}, Path=CurrentCulture}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DataGrid ItemsSource="{Binding Entries}"
                     SelectedItem="{Binding SelectedEntry}"
                     AutoGenerateColumns="False"
                     IsReadOnly="True"
                     SelectionMode="Single"
                     GridLinesVisibility="None"
                     VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{Binding Source={StaticResource Langs}, Path=[DataGrid_Date]}"
                                    Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                    Width="120"/>

                <DataGridTextColumn Header="{Binding Source={StaticResource Langs}, Path=[DataGrid_Result]}"
                                    Binding="{Binding Result, Converter={StaticResource EnumConverter}}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Column="1" Margin="25,0">

            <ui:TextBlock Text="{Binding Source={StaticResource Langs}, Path=[Title_DayDatails]}"
                          FontWeight="Bold"
                          FontSize="20"
                          Margin="0,0,0,15"/>

            <ui:Card Margin="0,0,0,15" Padding="15">
                <StackPanel>
                    <ui:TextBlock Appearance="Secondary">
                        <ui:TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}: {1:dd MMMM yyyy}">
                                <Binding Source="{StaticResource Langs}" Path="[DataGrid_Date]" />
                                <Binding Path="SelectedEntry.Date" />
                            </MultiBinding>
                        </ui:TextBlock.Text>
                    </ui:TextBlock>

                    <ui:TextBlock Margin="0,10,0,0" FontSize="16" FontWeight="Medium">
                        <ui:TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}: {1}">
                                <Binding Source="{StaticResource Langs}" Path="[DataGrid_Result]" />
                                <Binding Path="SelectedEntry.Result" Converter="{StaticResource EnumConverter}" />
                            </MultiBinding>
                        </ui:TextBlock.Text>
                    </ui:TextBlock>
                </StackPanel>
            </ui:Card>

            <Label Content="{Binding Source={StaticResource Langs}, Path=[Title_Description]}" 
                      Margin="0,5"/>

            <ScrollViewer Height="200" VerticalScrollBarVisibility="Visible">
                <ui:TextBox Text="{Binding SelectedEntry.Description}"
                        IsReadOnly="True"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalAlignment="Top"
                        VerticalContentAlignment="Top"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>